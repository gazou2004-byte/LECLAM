# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL publique du site (sans slash final) — utilisée pour les redirects et emails
DOMAIN=https://tondomaine.fr

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Clé admin — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=remplace_par_une_cle_aleatoire_32_caracteres_minimum

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
GMAIL_USER=tonadresse@gmail.com
# Mot de passe d'application Gmail (pas ton vrai mot de passe)
# → https://myaccount.google.com/apppasswords
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

OWNER_EMAIL=gazou2004@gmail.com
SUPPLIER_EMAIL=fournisseur@exemple.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── PayPal ────────────────────────────────────────────────────────────────────
# Compte marchand PayPal → https://developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=AXxx...
PAYPAL_SECRET=EGxx...
PAYPAL_ENV=production

# ── Virement bancaire ─────────────────────────────────────────────────────────
BANK_IBAN=FR76 1234 5678 9012 3456 7890 123
BANK_BIC=AGRIFRPP
BANK_NAME=Crédit Agricole

# ── Apple Pay (HTTPS + Apple Developer Program obligatoires) ─────────────────
# 1. Enregistrer le domaine dans Apple Pay Merchant Identity
# 2. Télécharger le fichier de vérification de domaine Apple
#    → le placer dans public/.well-known/apple-developer-merchantid-domain-association
# 3. Générer le certificat marchand (.pem) et la clé privée (.key.pem)
APPLE_MERCHANT_ID=merchant.eu.leclam
APPLE_CERT_PATH=/etc/ssl/apple-pay/apple-pay   # → lit apple-pay.pem + apple-pay-key.pem
